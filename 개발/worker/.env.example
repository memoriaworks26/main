# 메모리아웍스 렌더 워커 env — 복사해서 worker/.env 로 사용(절대 커밋 금지).
# 로컬·서버(Railway) 동일 값. 배포 시 이 내용을 그대로 붙여넣으면 됨.

# ── Supabase (서버 전용 service_role — 브라우저에 절대 노출 금지) ──
SUPABASE_URL=https://mgybnsidmnzjfqtucfhl.supabase.co
SUPABASE_SERVICE_KEY=

# ── 스토리지 버킷 ──
UPLOAD_BUCKET=memoria-uploads
FINAL_BUCKET=memoria-final

# ── AI = Higgsfield 단일(타이틀 이미지=Soul + 추억영상=DoP). OpenAI 불필요. ──
#    ※ 계정에 Higgsfield 크레딧 필요(없으면 생성요청이 403 "Not enough credits").
#    키 풀(우선순위순): main(_API_KEY) → 소진/오류 시 _API_KEY_2로 자동 폴백.
#    _API_KEY_2 는 선택(없으면 _API_KEY 단일로 동작).
HIGGSFIELD_API_KEY=
HIGGSFIELD_SECRET=
HIGGSFIELD_API_KEY_2=
HIGGSFIELD_SECRET_2=

# ── 동작 ──
POLL_INTERVAL_MS=5000
MAX_ATTEMPTS=3
# 동시 렌더 수(피크 흡수). 각 렌더는 대기시간이 길어 병렬 효과 큼. Railway 레플리카와 병행해도 안전(claim=SKIP LOCKED).
CONCURRENCY=2
# rendering이 이 분(min) 이상 멈추면 리퍼가 재큐(시도초과면 failed) — Railway 재배포·크래시 복구.
STALE_RENDER_MIN=15
REAPER_INTERVAL_MS=60000
# 렌더 스텁(가짜 결과) — 개발용. 1일 때만 켜짐(기본 0=실제 렌더). 운영에선 절대 1로 두지 말 것.
#   (안전장치: NODE_ENV=production 인데 1이면 워커가 기동을 거부함.)
WORKER_STUB=0
# 진행 중 작업 생존 신호 주기(ms) — reaper STALE_RENDER_MIN(15분)보다 훨씬 짧게. 긴 합성이 멈춤으로 오판되는 것 방지.
HEARTBEAT_MS=120000

# ── 완성본/소스 서명URL 만료(초) — 예약 종료일 기준, 아래는 하한·기본값 ──
VIDEO_MIN_EXPIRY_SEC=259200      # 최소 3일(검수·발인 당일 여유)
VIDEO_DEFAULT_EXPIRY_SEC=2592000 # 종료일 없을 때 30일

# ── ffmpeg 바이너리 경로 — 운영(Linux)은 apt ffmpeg(drawtext 포함) 주입 필수. 미설정 시 ffmpeg-static 폴백(Linux엔 drawtext 없어 한글 자막 깨짐). ──
# (Dockerfile에서 ENV로 설정됨. 로컬은 보통 비워둬 ffmpeg-static 사용)
FFMPEG_PATH=
FFPROBE_PATH=

# ── Higgsfield 출력/폴링 옵션(선택, 기본값 있음) ──
HIGGSFIELD_IMG_ASPECT=16:9   # seedream 이미지 가로세로비
HIGGSFIELD_IMG_RES=2K        # seedream 해상도
HIGGSFIELD_VID_ASPECT=16:9   # kling(영상은 입력 사진 비율을 따름 — 참고용)
HIGGSFIELD_POLL_MS=720000    # 영상 생성 폴링 타임아웃(기본 12분, reaper 15분보다 짧게)
HIGGSFIELD_429_RETRY=4       # 같은 키 429 재시도 횟수(1·2·4·8초 백오프)
