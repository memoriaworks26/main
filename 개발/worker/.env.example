# 메모리아웍스 렌더 워커 env — 복사해서 worker/.env 로 사용(절대 커밋 금지).
# 로컬·서버(Railway) 동일 값. 배포 시 이 내용을 그대로 붙여넣으면 됨.

# ── Supabase (서버 전용 service_role — 브라우저에 절대 노출 금지) ──
SUPABASE_URL=https://mgybnsidmnzjfqtucfhl.supabase.co
SUPABASE_SERVICE_KEY=

# ── 스토리지 버킷 ──
UPLOAD_BUCKET=memoria-uploads
FINAL_BUCKET=memoria-final

# ── AI = Higgsfield 단일(타이틀 이미지=Soul + 추억영상=DoP). OpenAI 불필요. ──
#    ※ 계정에 Higgsfield 크레딧 필요(없으면 생성요청이 403 "Not enough credits").
#    키 풀(우선순위순): main(_API_KEY, _API_KEY_2) → 소진/오류 시 sub(_SUB_API_KEY)로 자동 폴백.
#    _API_KEY_2 / _SUB_* 는 선택(없으면 _API_KEY 단일로 동작).
HIGGSFIELD_API_KEY=
HIGGSFIELD_SECRET=
HIGGSFIELD_API_KEY_2=
HIGGSFIELD_SECRET_2=
HIGGSFIELD_SUB_API_KEY=
HIGGSFIELD_SUB_SECRET=

# ── 동작 ──
POLL_INTERVAL_MS=5000
MAX_ATTEMPTS=3
# 동시 렌더 수(피크 흡수). 각 렌더는 대기시간이 길어 병렬 효과 큼. Railway 레플리카와 병행해도 안전(claim=SKIP LOCKED).
CONCURRENCY=2
# rendering이 이 분(min) 이상 멈추면 리퍼가 재큐(시도초과면 failed) — Railway 재배포·크래시 복구.
STALE_RENDER_MIN=15
REAPER_INTERVAL_MS=60000
# 1 = 렌더 스텁(가짜 결과). ⚠️ 운영 배포 시 반드시 0 (안 그러면 보호자에게 가짜 영상 전달).
WORKER_STUB=1
