# 메모리아웍스 렌더 워커 env — 복사해서 worker/.env 로 사용(절대 커밋 금지).
# 로컬·서버(Render) 동일 값. 배포 시 이 내용을 그대로 붙여넣으면 됨.

# ── Supabase (서버 전용 service_role — 브라우저에 절대 노출 금지) ──
SUPABASE_URL=https://lvrirxtfjeuwionjluxf.supabase.co
SUPABASE_SERVICE_KEY=

# ── 스토리지 버킷 ──
UPLOAD_BUCKET=memoria-uploads
FINAL_BUCKET=memoria-final

# ── AI = Higgsfield 단일(타이틀 이미지=Soul + 추억영상=DoP). OpenAI 불필요. ──
#    ※ 계정에 Higgsfield 크레딧 필요(없으면 생성요청이 403 "Not enough credits").
HIGGSFIELD_API_KEY=
HIGGSFIELD_SECRET=

# ── 동작 ──
POLL_INTERVAL_MS=5000
MAX_ATTEMPTS=3
# 1 = 렌더 스텁(아직 AI/FFmpeg 미구현 단계). 실제 렌더 붙이면 0.
WORKER_STUB=1
